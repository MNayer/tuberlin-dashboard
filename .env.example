# Copy this file to `.env` (next to docker-compose.yml). Docker Compose loads
# `.env` automatically. `.env` itself is gitignored.

# --- App ---
# Secret key used to sign session cookies. Generate a fresh one with:
#   python3 -c 'import secrets; print(secrets.token_urlsafe(48))'
SECRET_KEY=replace-with-long-random-string

# Password for the /admin area. Anyone with this can edit buildings,
# review suggestions, and edit Reisekosten entries.
ADMIN_PASSWORD=please-change-me

# Public base URL of the app — used to build absolute magic-link URLs
# in login emails. No trailing slash.
APP_BASE_URL=https://dashboard.tu-berlin.de

# Only addresses ending in @<domain> may request a magic link.
ALLOWED_EMAIL_DOMAIN=tu-berlin.de

# A Reisekosten item counts as "overdue" if its Abrechnung was submitted
# more than this many months ago and it hasn't been settled.
REISEKOSTEN_OVERDUE_MONTHS=6

# --- SMTP (optional) ---
# If SMTP_HOST is empty, magic links are printed to the container logs
# instead of being emailed (useful for local development).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@tu-berlin.de
SMTP_USE_TLS=true

# Example for a real SMTP setup (uncomment and adjust):
# SMTP_HOST=mail.tu-berlin.de
# SMTP_PORT=587
# SMTP_USER=dashboard-bot
# SMTP_PASSWORD=super-secret
# SMTP_FROM=dashboard@tu-berlin.de
# SMTP_USE_TLS=true
